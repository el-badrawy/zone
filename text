hoodies.js 
const products = [
  {
    name: "هودي أسود",
    price: 300,
    hofer: 200,
    img: "https://images.unsplash.com/photo-1523381210434-271e8be1f52b",
  }
];

const container = document.getElementById("products");

products.forEach((p, i) => {
  container.innerHTML += `
    <div class="card">
      <img src="${p.img}">
      <h3>${p.name}</h3>

      ${p.hofer ? `<del>${p.hofer} جنيه</del>` : ""}

      <p>${p.price} جنيه</p>

      <select id="size${i}">
        <option value="">المقاس</option>
        <option>M</option>
        <option>L</option>
        <option>XL</option>
      </select>

      <select id="color${i}">
        <option value="">اللون</option>
        <option>أسود</option>
        <option>أبيض</option>
        <option>رمادي</option>
      </select>

      <button onclick="addToCart(${i})">اضف للسلة</button>
    </div>
  `;
});

function addToCart(i) {
  let cart = JSON.parse(localStorage.getItem("cart")) || [];

  let size = document.getElementById(`size${i}`).value;
  let color = document.getElementById(`color${i}`).value;

  cart.push({ ...products[i], size, color });

  localStorage.setItem("cart", JSON.stringify(cart));
  alert("تم الإضافة 🛒");
}





